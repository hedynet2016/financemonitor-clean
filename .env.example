# WorkBuddy 環境變數配置範例
# 複製此文件為 .env 並填入實際值

# ==================== Telegram 配置 ====================
TELEGRAM_BOT_TOKEN=你的Telegram_Bot_Token
TELEGRAM_CHAT_ID=你的Chat_ID

# ==================== Discord 配置 ====================
DISCORD_WEBHOOK_URL=你的Discord_Webhook_URL

# ==================== Gmail 配置 ====================
GMAIL_SENDER=你的Gmail地址
GMAIL_APP_PASSWORD=你的Gmail_App_Password
REPORT_RECIPIENT=報告接收者郵箱

# ==================== GitHub 配置 ====================
GITHUB_PAT=你的GitHub_Personal_Access_Token
GITHUB_USER=hedynet2016
GITHUB_REPO_BACKUP=workbuddy-backup

# ==================== Render 配置 ====================
RENDER_URL=你的Render應用URL

# ==================== 監控配置 ====================
MONITOR_INTERVAL=300
